{
  "name": "mapa-turistico-quindio",
  "version": "1.0.0",
  "description": "Mapa Turístico del Quindío - Plataforma turística programática",
  "main": "generator.js",
  "scripts": {
    "validate-data": "node ./scripts/validate-master-data.js",
    "generate-data": "node ./scripts/generate-data.js",
    "generate-geojson": "node ./scripts/generate-geojson.js",
    "generate-pages": "node ./scripts/generate-pages.js",
    "generate-sitemap": "node ./scripts/generate-sitemap.js",
    "validate-seo": "node ./scripts/validate-seo.js",
    "verify-canonical": "node ./scripts/verify-canonical.js",
    "ping-gsc": "node ./scripts/ping-gsc.js",
    "validate-pages": "node ./scripts/validate-pages.js",
    "enhance-schema": "node ./scripts/enhance-schema.js",
    "audit-performance": "node ./scripts/audit-performance.js",
    "build": "npm run validate-data && npm run generate-data && npm run generate-geojson && npm run generate-pages && npm run generate-sitemap && npm run verify-canonical && npm run validate-seo",
    "test": "npm run validate-data && npm run validate-pages && npm run validate-seo && npm run audit-performance"
  },
  "keywords": ["turismo", "quindio", "mapa", "programmatic-seo", "eje-cafetero"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jsdom": "^26.0.0",
    "http-server": "^14.1.1",
    "lighthouse": "^13.4.0",
    "sharp": "^0.32.0"
  }
}
